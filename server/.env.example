# Base de datos
MONGODB_URI=mongodb://localhost:27017/sbeltic_dev

# JWT — usar un string aleatorio de al menos 32 caracteres en producción
JWT_SECRET=cambia-esto-por-un-string-aleatorio-seguro-de-32-chars
JWT_EXPIRE=7d

# Entorno
NODE_ENV=development
PORT=4000

# Cliente (requerido en producción)
CLIENT_URL=http://localhost:3000

# Credenciales del admin inicial (solo para correr node seed.js)
ADMIN_EMAIL=admin@sbeltic.com
ADMIN_PASSWORD=CambiarDespuesDelPrimerLogin!
